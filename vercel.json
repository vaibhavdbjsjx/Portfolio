{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/models/character.enc",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/models/char_enviorment.hdr",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/vnd.radiance"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|models/|images/|certificates/|draco/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
